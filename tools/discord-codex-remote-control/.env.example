DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_WEBHOOK_URL=

# Comma-separated Discord user IDs. Leave empty only for a private test server.
ALLOWED_USER_IDS=

# Optional path. Defaults to ./data/commands.jsonl
COMMAND_QUEUE_PATH=

# Set true after enabling Message Content Intent in the Discord Developer Portal.
ENABLE_REPLY_CAPTURE=false

# Codex runner settings. The runner watches COMMAND_QUEUE_PATH and runs pending tasks.
CODEX_RUNNER_ENGINE=app-server
CODEX_WORKSPACE_ROOT=
CODEX_EXECUTABLE=codex.cmd
CODEX_MODEL=
CODEX_SANDBOX=workspace-write

# Keeps one Codex CLI thread across Discord tasks. Leave CODEX_RUNNER_THREAD_ID empty
# to let the runner store the first created thread in RUNNER_STATE_PATH.
CODEX_RESUME_ENABLED=true
CODEX_RUNNER_THREAD_ID=

RUNNER_STATE_PATH=
RUNNER_POLL_INTERVAL_MS=3000
APP_SERVER_TURN_TIMEOUT_MS=1200000

# Re-open Codex Desktop on the updated thread after Discord turns complete.
REFRESH_CODEX_DESKTOP=true
CODEX_DESKTOP_REFRESH_BOUNCE=true
CODEX_DESKTOP_REFRESH_DELAY_MS=800
